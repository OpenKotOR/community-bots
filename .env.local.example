# ──────────────────────────────────────────────────────────────────────────────
# community-bots — unified local .env
# Copy to `.env` in the repo root and fill in all required values.
# The config package walks up from cwd so all apps share this file.
# ──────────────────────────────────────────────────────────────────────────────

# ── TRASK DISCORD BOT ─────────────────────────────────────────────────────────
TRASK_DISCORD_APP_ID=
TRASK_DISCORD_PUBLIC_KEY=
TRASK_DISCORD_BOT_TOKEN=
TRASK_DISCORD_GUILD_ID=          # optional: fast registration for a single guild
TRASK_ALLOWED_GUILD_IDS=
TRASK_APPROVED_CHANNEL_IDS=

# ── HK-86 DISCORD BOT ─────────────────────────────────────────────────────────
HK_DISCORD_APP_ID=
HK_DISCORD_PUBLIC_KEY=
HK_DISCORD_BOT_TOKEN=

# ── PAZAAK DISCORD BOT ────────────────────────────────────────────────────────
PAZAAK_DISCORD_APP_ID=
PAZAAK_DISCORD_PUBLIC_KEY=
PAZAAK_DISCORD_BOT_TOKEN=

# ── LLM / RESEARCH (optional — enables live synthesis in Trask Q&A) ───────────
# Option A: OpenAI (paid)
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Option B: OpenRouter (free tier: https://openrouter.ai → sign up free)
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# TRASK_REWRITE_MODEL_FALLBACKS=meta-llama/llama-3.2-3b-instruct:free,openrouter/auto

# ── TRASK HTTP SERVER ─────────────────────────────────────────────────────────
TRASK_HTTP_PORT=4010
TRASK_WEB_ALLOW_ANONYMOUS=1
TRASK_WEB_DEFAULT_USER_ID=dev
TRASK_GPT_RESEARCHER_ROOT=./vendor/ai-researchwizard
TRASK_GPT_RESEARCHER_PYTHON=./.venv-trask-gptr/bin/python
TRASK_RESEARCHWIZARD_TIMEOUT_MS=120000

# ── PAZAAK WORLD (Vite SPA) ────────────────────────────────────────────────────
# Backend mode: "nakama" (local Nakama server) or "legacy" (HTTP bot API).
# Leave VITE_PAZAAK_BACKEND unset (or "legacy") for the bot-based HTTP flow.
# Set to "nakama" and fill VITE_NAKAMA_HOST to use the local Nakama server.
# VITE_PAZAAK_BACKEND=nakama
# VITE_NAKAMA_HOST=127.0.0.1
# VITE_NAKAMA_PORT=7350
# VITE_NAKAMA_SERVER_KEY=defaultkey

# Legacy HTTP origin — used for OAuth token exchange even when Nakama is active.
VITE_LEGACY_HTTP_ORIGIN=http://localhost:4001

# Optional comma-separated API origins (bot-based HTTP fallback chain).
# VITE_API_BASES=http://localhost:4001
